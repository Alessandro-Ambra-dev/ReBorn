{
  "expo": {
    "name": "ReBorn",
    "slug": "reborn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ReBorn_icon.png",
    "scheme": [
      "reborn",
      "com.googleusercontent.apps.2634578916-9i6a93ov9p2c4sib59sqs5r0sui5uf7o"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/ReBorn_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "transparent"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reborn.app"
    },
    "android": {
      "buildToolsVersion": "35.0.0",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ReBorn_icon.png",
        "monochromeImage": "./assets/images/ReBorn_icon.png",
        "backgroundColor": "transparent"
      },
      "package": "com.reborn.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/ReBorn_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-web-browser"
    ]
  }
}
