{
  "expo": {
    "name": "ReBorn",
    "slug": "reborn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ReBorn_icon.png",
    "scheme": "reborn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/ReBorn_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reborn.app"
    },
    "android": {
      "buildToolsVersion": "35.0.0",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ReBorn_icon.png",
        "monochromeImage": "./assets/images/ReBorn_icon.png",
        "backgroundColor": "#00000000"
      },
      "package": "com.reborn.app",
      "androidNavigationBar": {
        "backgroundColor": "#0f172a",
        "barStyle": "light-content"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/ReBorn_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-web-browser"
    ]
  }
}
